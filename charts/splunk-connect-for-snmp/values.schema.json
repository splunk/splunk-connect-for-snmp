          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "token": {
          "type": "string",
          "description": "Plaintext HEC token. Omit when using tokenSecretRef."
        },
        "tokenSecretRef": {
          "type": "object",
          "additionalProperties": false,
          "description": "Reference to an existing secret containing the HEC token (alternative to plaintext token).",
