            "name": {
              "type": "string",
              "description": "Name of the existing Kubernetes secret."
            },
            "key": {
              "type": "string",
              "description": "Key within the secret that holds the HEC token.",
              "default": "hec_token"
            }
          }
        },
        "tokenFilePath": {
          "type": "string",
          "description": "Path to file containing HEC token (e.g. /vault/secrets/splunk-hec-token). When set, SPLUNK_HEC_TOKEN_FILE is used and SPLUNK_HEC_TOKEN is not set from a Secret."
